{
  "name": "nexus-audio",
  "version": "2.0.3",
  "description": "Nexus Audio - Modern music player & downloader",
  "main": "src/main/main.js",
  "author": "Punyapat",
  "license": "MIT",
  "homepage": "https://github.com/punyapat/nexus-audio",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "dev:css": "tailwindcss -i ./src/tailwind.css -o ./src/renderer/css/tailwind-built.css --watch",
    "build:css": "tailwindcss -i ./src/tailwind.css -o ./src/renderer/css/tailwind-built.css --minify",
    "build": "npm run build:css && electron-builder --linux",
    "build:deb": "npm run build:css && electron-builder --linux deb",
    "build:appimage": "npm run build:css && electron-builder --linux AppImage"
  },
  "build": {
    "appId": "com.nexus.audio",
    "productName": "Nexus Audio",
    "linux": {
      "target": [
        "deb",
        "AppImage",
        "pacman"
      ],
      "icon": "build/icon.png",
      "category": "AudioVideo;Audio;Player;",
      "maintainer": "Punyapat",
      "synopsis": "Modern music player & downloader"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "@phosphor-icons/web": "^2.1.2",
    "music-metadata": "^7.14.0"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^3.4.19"
  }
}
